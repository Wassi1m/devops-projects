# Environment Configuration - Development
ENVIRONMENT=development
ASPNETCORE_ENVIRONMENT=Development

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=bourseia
DB_PASSWORD=secret123
DB_NAME=bourseia_db_dev

# API Configuration
API_PORT=8080
API_URL=http://localhost:5000

# AI Service Configuration
AI_PORT=8000
AI_URL=http://localhost:8000
DETECTION_API_URL=http://localhost:8000/predict

# Observability Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=bourseia-api-dev
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SDK_DISABLED=false

# Prometheus Configuration
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=7d
PROMETHEUS_SCRAPE_INTERVAL=30s

# Grafana Configuration
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false

# Loki Configuration
LOKI_PORT=3100
LOKI_RETENTION_PERIOD=24h

# Alertmanager Configuration
ALERTMANAGER_PORT=9093
SLACK_WEBHOOK_URL=
PAGERDUTY_SERVICE_KEY=

# Jaeger Configuration
JAEGER_PORT=16686
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831

# Logging
LOG_LEVEL=Debug
SERILOG_MINIMUM_LEVEL=Debug

# Security
JWT_SECRET=dev-super-secret-jwt-key
API_KEY=dev-api-key

# Docker Registry
REGISTRY=docker.io
REGISTRY_USERNAME=
REGISTRY_PASSWORD=

# Kubernetes
KUBE_CONTEXT=docker-desktop
KUBE_NAMESPACE=coin-system-dev

